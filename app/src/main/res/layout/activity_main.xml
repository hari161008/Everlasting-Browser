<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="ContentDescription">

    <!-- Page progress indicator — full-width, sits at very top -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/main_progress_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"
        app:trackCornerRadius="4dp"
        app:indicatorColor="?attr/colorPrimary"
        app:trackColor="?attr/colorSurfaceContainerHighest" />

    <!-- WebView content — leaves room for the floating omnibar -->
    <FrameLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="88dp" />

    <!-- ── Unified Omnibar — all features in one container ──────────── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layout"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_gravity="bottom"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="34dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp">

            <!-- Security lock indicator -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/omnibox_security_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/icon_lock"
                app:tint="?attr/colorPrimary"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Expressive.Circle"
                tools:ignore="ContentDescription" />

            <!-- Page title / URL — tappable to open search -->
            <TextView
                android:id="@+id/omniBox_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:singleLine="true"
                android:ellipsize="end"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textStyle="bold" />

            <!-- Vertical divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="4dp"
                android:background="?attr/colorOutlineVariant" />

            <!-- Overview / bookmarks button -->
            <ImageButton
                android:id="@+id/omnibox_overview"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@android:color/transparent"
                android:src="@drawable/icon_bookmark"
                app:tint="?attr/colorOnSurfaceVariant"
                tools:ignore="ContentDescription" />

            <!-- Overflow / menu FAB -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/omniBox_tab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="4dp"
                android:src="@drawable/icon_overflow"
                android:backgroundTint="?attr/colorPrimaryContainer"
                app:tint="?attr/colorOnPrimaryContainer"
                app:fabCustomSize="44dp"
                app:maxImageSize="22dp"
                app:elevation="0dp"
                app:borderWidth="0dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
