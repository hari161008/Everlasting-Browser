<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- Search suggestions list -->
    <ListView
        android:id="@+id/list_search"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="@null"
        android:fastScrollEnabled="true"
        android:stackFromBottom="true"
        android:paddingBottom="164dp"
        android:clipToPadding="false" />

    <!-- ── Unified search panel — matches omnibar design ─────────────── -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <!-- URL / search input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textField"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/main_omnibox_input_hint"
                app:boxCornerRadiusTopStart="24dp"
                app:boxCornerRadiusTopEnd="24dp"
                app:boxCornerRadiusBottomStart="24dp"
                app:boxCornerRadiusBottomEnd="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/omniBox_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text|textUri"
                    android:selectAllOnFocus="true"
                    android:imeOptions="actionGo" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Action buttons row -->
            <LinearLayout
                android:id="@+id/buttonsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="10dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/omnibox_close"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    app:icon="@drawable/icon_close"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Expressive.ExtraLarge" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/omnibox_search"
                    style="@style/Widget.Material3.Button.IconButton.Filled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    app:icon="@drawable/icon_search"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Expressive.ExtraLarge" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/omnibox_customSearch"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/icon_custom_searches"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Expressive.ExtraLarge" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
